{
  "identifier": "default",
  "description": "Default capability for OmniBank",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-execute",
    "shell:allow-spawn",
    "shell:allow-kill",
    "shell:allow-open",
    "updater:default",
    "core:app:default",
    "dialog:allow-open"
  ],
  "remote": {
    "urls": [
      "http://127.0.0.1:8434",
      "http://127.0.0.1:8434/**"
    ]
  }
}
